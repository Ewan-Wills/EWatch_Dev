# Unit cube centered at origin, side length 2. CCW winding when viewed from
# outside (standard OBJ convention). 8 vertices, 12 triangles.
#
# This file is the source-of-truth model. cube_obj.h mirrors its contents as
# C arrays for the renderer (the watch firmware can't parse OBJ on the fly
# without a filesystem). If you edit this, regenerate the .h to match.

v -1 -1 -1
v  1 -1 -1
v  1  1 -1
v -1  1 -1
v -1 -1  1
v  1 -1  1
v  1  1  1
v -1  1  1

# Faces (1-indexed, OBJ convention).
# -Z face (back)
f 1 4 3
f 1 3 2
# +Z face (front)
f 5 6 7
f 5 7 8
# -Y face (bottom)
f 1 2 6
f 1 6 5
# +Y face (top)
f 4 8 7
f 4 7 3
# -X face (left)
f 1 5 8
f 1 8 4
# +X face (right)
f 2 3 7
f 2 7 6
